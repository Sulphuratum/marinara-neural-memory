# Copy this file to .env (in this same bridge/ folder) and fill in your values.

# Port the bridge listens on locally. Point the webhookUrl in
# functions/marinara-functions.json at this port (default already matches).
BRIDGE_PORT=8135

# Base URL of your running shodh-memory server (`shodh server`).
SHODH_BASE_URL=http://localhost:3030

# API key generated by `shodh init`.
SHODH_API_KEY=

# Set to true to log every outbound request to shodh (URL, body, response status/timing
# or connection failure) to the console. Useful for debugging; leave unset in normal use.
SHODH_BRIDGE_DEBUG=
